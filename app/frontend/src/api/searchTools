import { supabase } from '../lib/supabase';
import { type PricingPreference, type Tool } from '../lib/api';

function normalizeSearchTool(tool: Tool): Tool {
  const canonicalUrl = (tool.url || tool.website_url || '').trim();
  const canonicalAffiliateUrl = (tool.affiliateUrl || tool.affiliate_url || '').trim();

  return {
    ...tool,
    url: canonicalUrl || undefined,
    website_url: canonicalUrl || undefined,
    affiliateUrl: canonicalAffiliateUrl || undefined,
    affiliate_url: canonicalAffiliateUrl || undefined,
  };
}

export async function searchTools(
  searchQuery: string,
  pricingPreference: PricingPreference = 'any',
  category?: string,
  limit = 24
): Promise<Tool[]> {
  const cleanQuery = searchQuery.trim();
  if (!cleanQuery) return [];

  const { data, error } = await supabase.rpc('search_tools', {
    search_query: cleanQuery,
    pricing_filter: pricingPreference,
    category_filter: category || null,
    limit_count: limit,
  });

  if (error) {
    console.error('Error searching tools:', error);
    throw error;
  }

  return (data ?? []).map((tool) => normalizeSearchTool(tool as Tool));
}